# ========================================
# SynthEdge — Environment Configuration
# ========================================

# --- Synth API ---
SYNTH_API_KEY=your_synth_api_key_here
SYNTH_POLL_INTERVAL_SECONDS=300
SYNTH_CACHE_TTL_SECONDS=600

# --- PostgreSQL ---
POSTGRES_USER=synthedge
POSTGRES_PASSWORD=synthedge_dev_password
POSTGRES_DB=synthedge
POSTGRES_URL=postgresql+asyncpg://synthedge:synthedge_dev_password@localhost:5432/synthedge

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Backend ---
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info

# --- Frontend (set at build time!) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Mock data fallback ---
SAVE_MOCK_DATA=true
